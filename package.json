{
  "name": "llm-fw",
  "version": "0.3.0",
  "description": "Local LLM prompt injection firewall",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "bin": {
    "llm-fw": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PIsberg/llm-fw.git"
  },
  "homepage": "https://github.com/PIsberg/llm-fw#readme",
  "bugs": {
    "url": "https://github.com/PIsberg/llm-fw/issues"
  },
  "keywords": [
    "llm",
    "prompt-injection",
    "firewall",
    "security",
    "proxy",
    "ai-security",
    "dlp",
    "mcp"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:load:perf": "node --import tsx/esm test/load/performance.ts",
    "test:load:accuracy": "node --import tsx/esm test/load/accuracy.ts",
    "test:load": "npm run test:load:perf && npm run test:load:accuracy",
    "load:charts": "node --import tsx/esm scripts/gen-load-charts.ts",
    "scorecard": "node --import tsx/esm scripts/gen-scorecard.ts",
    "bench:competitors": "node --import tsx/esm test/eval/competitors/run.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "cosmiconfig": "^9.0.2",
    "node-forge": "^1.3.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^26.0.0",
    "@types/node-forge": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "knip": "^6.16.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
