{
  "name": "llm-fw",
  "version": "0.1.0",
  "description": "Local LLM prompt injection firewall",
  "type": "module",
  "bin": {
    "llm-fw": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:load:perf": "node --import tsx/esm test/load/performance.ts",
    "test:load:accuracy": "node --import tsx/esm test/load/accuracy.ts",
    "test:load": "npm run test:load:perf && npm run test:load:accuracy",
    "load:charts": "node --import tsx/esm scripts/gen-load-charts.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "cosmiconfig": "^9.0.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "knip": "^6.15.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
